body { font-family: Arial, sans-serif; display: flex; justify-content: center; padding-top: 50px; background-color: #f4f4f4; }
.container { background: white; padding: 20px; border-radius: 10px; box-shadow: 0 0 10px rgba(0,0,0,0.1); width: 350px; text-align: center; }
input { width: 90%; padding: 10px; margin-bottom: 10px; }
button { padding: 10px 20px; cursor: pointer; background: #007bff; color: white; border: none; border-radius: 5px; }

/* Department: Design - Styles for the new result list */
.result-item {
    margin-top: 10px;
    padding: 10px;
    background: #e9ecef;
    border-radius: 5px;
    word-break: break-all;
    font-size: 14px;
}
